#!/bin/sh

set -eu

exit_status=0

# Check installed binaries
binaries=$(jq -r '.[]' ~/.config/scripts/setup/binaries.json)
while read -r bin || [ -n "$bin" ]; do
    command -v "$bin" >/dev/null 2>&1 || {
        echo "$bin cannot be found in \$PATH" >&2
        exit_status=1
    }
done <<EOF
$binaries
EOF

# Check fstab entries
fstab_entries=$(cat ~/.config/scripts/setup/fstab.json)
entry_devices=$(printf '%s' "$fstab_entries" | jq -r 'keys[]')
while read -r device || [ -n "$device" ]; do
    pattern=$(printf '%s' "$fstab_entries" | jq -r --arg device "$device" '.[$device]')

    grep -qE "$pattern" /etc/fstab || {
        echo "$device entry missing from /etc/fstab" >&2
        exit_status=1
    }
done <<EOF
$entry_devices
EOF

exit $exit_status
