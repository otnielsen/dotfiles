#!/bin/sh

set -eu

if [ -t 0 ]; then
    export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS --bind \"enter:become(printf '%s' {n})\""
    menu='fzf --read0'
    cmd='ssh'
else
    menu='fuzzel --dmenu0 --only-match --index'
    cmd="$TERMINAL -e ssh"
fi

menu_options='[
"jellyfin@192.168.1.213",
"root@192.168.1.53"
]'

choice=$(printf '%s' "$menu_options" | jq --raw-output0 '.[]' | $menu)
[ -z "$choice" ] || [ "$choice" -lt 0 ] && exit 1

host=$(printf '%s' "$menu_options" | jq -r --argjson choice "$choice" '.[$choice]')
[ "$host" = 'null' ] || [ -z "$host" ] && exit 1

exec $cmd "$host"
