{
  "vim_mode": true,
  "disable_ai": true,
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "relative_line_numbers": true,
  "soft_wrap": "editor_width",
  "terminal": {
    "dock": "right",
    "env": {
      "EDITOR": "zed --wait",
      "VISUAL": "zed --wait"
    },
    "toolbar": {
      "breadcrumbs": false
    }
  },
  "lsp": {
    "jdtls": {
      "initialization_options": {
        "settings": {
          "java": {
            "jdt": {
              "ls": {
                "lombokSupport": {
                  "enabled": true
                }
              }
            },
            "configuration": {
              "maven": {
                "globalSettings": "/home/olive/.config/maven/settings.xml"
              }
            }
          }
        }
      }
    },
    "bash-language-server": {
      "binary": {
        "path": "/usr/bin/bash-language-server",
        "arguments": [
          "start"
        ]
      }
    }
  },
  "auto_install_extensions": {
    "basher": true,
    "emmet": true,
    "git-firefly": true,
    "java": true,
    "material-icon-theme": true,
    "ruff": true,
    "toml": true,
    "ty": true
  },
  "languages": {
    "Python": {
      "language_servers": [
        "ruff",
        "ty"
      ],
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true
      }
    },
    "Java": {
      "format_on_save": "off"
    }
  },
  "icon_theme": "Material Icon Theme"
}
