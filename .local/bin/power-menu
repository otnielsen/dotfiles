#!/bin/sh

set -eu

if [ -t 0 ]; then
    menu='fzf --read0'
else
    menu='fuzzel --dmenu0'
fi

menu_options='{
"\uf4ee  sleep": "systemctl suspend",
"\uf011  poweroff": "systemctl poweroff",
"\uf46a  reboot": "systemctl reboot",
"\uf456  lock": "loginctl lock-session",
"\uf42a  logout": "loginctl terminate-user '"$USER"'",
"\uec19  firmware": "systemctl reboot --firmware-setup"
}'

choice=$(printf '%s' "$menu_options" | jq --raw-output0 'keys_unsorted[]' | $menu)
[ -z "$choice" ] && exit 1

cmd=$(printf '%s' "$menu_options" | jq -r --arg choice "$choice" '.[$choice]')
[ "$cmd" = 'null' ] || [ -z "$cmd" ] && exit 1

exec $cmd
